que="false" isMappable="true" isNode="true" key="42" mandatory="false" name="Field28"><DataFormat><ProfileCharacterFormat/></DataFormat></DatabaseElement><DatabaseElement enforceUnique="false" isMappable="true" isNode="true" key="44" mandatory="false" name="Field29"><DataFormat><ProfileCharacterFormat/></DataFormat></DatabaseElement><DatabaseElement enforceUnique="false" isMappable="true" isNode="true" key="46" mandatory="false" name="Field30"><DataFormat><ProfileCharacterFormat/></DataFormat></DatabaseElement><DatabaseElement enforceUnique="false" isMappable="true" isNode="true" key="48" mandatory="false" name="Field31"><DataFormat><ProfileCharacterFormat/></DataFormat></DatabaseElement></DBFields><DBParameters isNode="true" key="4" name="Parameters"/><sql>SELECT 
SAP連係用燃種ID &amp; UniqueID &amp; 品目分類CD,
'01',
T_計上情報.計上ID,
T_精算金額.計上回数,
T_計上情報.取引先CD,
T_計上情報.取引先CD,
T_精算金額.計上年月日,
T_計上情報.通貨CD,
T_精算金額.計上額,
[計上額_JPY],
T_精算金額.消費税額,
T_精算金額.計上レート,
T_受入情報.揚地,
T_受入情報.燃種CD,
T_受入情報.品種CD,
T_受入情報.[銘柄],
T_受入情報.[受入年月日],
T_受入情報.[積地],
T_受入情報.[カーゴ／ロットNo],
M_受渡条件定数.FIMS連係用受渡条件CD,
T_受入情報.船名,
T_燃種別検収情報_石炭.全水分,
T_燃種別検収情報_石炭.[数量（湿）],
T_燃種別検収情報_石炭.[数量（乾）],
T_燃種別検収情報_石炭.[単位発熱量（湿）_TE],
T_燃種別検収情報_石炭.[単位発熱量（湿）],
T_燃種別検収情報_石炭.硫黄分,
T_燃種別検収情報_石炭.硫黄分積数,
T_燃種別検収情報_石炭.灰分,
T_燃種別検収情報_石炭.灰分積数,
T_燃種別検収情報_石炭.熱量


FROM
T_概算計上金額情報　INNER JOIN T_受入情報　ON T_受入情報.UniqueID =  T_概算計上金額情報.UniqueID
INNER JOIN C_燃種変換 ON T_受入情報.燃種CD = C_燃種変換.燃種CD
INNER JOIN T_計上情報 ON T_受入情報.UniqueID = T_計上情報.UniqueID
INNER JOIN T_精算金額 ON T_計上情報.UniqueID = T_精算金額.UniqueID AND T_計上情報.計上ID = T_精算金額.計上ID
INNER JOIN M_受渡条件定数 ON T_受入情報.受渡条件CD = M_受渡条件定数.受渡条件CD
INNER JOIN T_燃種別検収情報_石炭 ON T_受入情報.UniqueID = T_燃種別検収情報_石炭.UniqueID

WHERE UniqueID = "20190228"</sql></DBStatement></DataElements></DatabaseProfile></bns:object></bns:Component>