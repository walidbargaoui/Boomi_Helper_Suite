function mapToHankaku(character) {
  var zenHanMap = getZenkakuToHankakuMap();
  if (typeof zenHanMap[character] === 'undefined') {
    return character;
  } else {
    return zenHanMap[character];
  }
}

function getCharacters(string) {
   return string.split("");
}

function convertToHalfWidth(string) {
  var characters = getCharacters(string);
  var halfWidthString = '';
  for(i=0;i&lt;characters.length;i++)
    halfWidthString = halfWidthString + mapToHankaku(characters[i]);

  return halfWidthString;
}


